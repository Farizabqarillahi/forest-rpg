  "npcs": [
    {
      "id": "elder",
      "name": "Elder Mira",
      "role": "quest_giver",
      "x": 12, "y": 10,
      "sprite": "npc_elder",
      "schedule": [
        { "startHour": 6,  "endHour": 12, "behavior": "patrol", "path": [[12,10],[16,10],[16,14],[12,14]] },
        { "startHour": 12, "endHour": 18, "behavior": "idle",   "position": [14, 12] },
        { "startHour": 18, "endHour": 24, "behavior": "idle",   "position": [12, 10] },
        { "startHour": 0,  "endHour": 6,  "behavior": "idle",   "position": [12, 10] }
      ],
      "dialogue": {
        "initial": {
          "text": "Greetings, traveler! Our village is threatened by wolves and restless spirits. Will you help us?",
          "choices": [
            { "text": "I'll help! What do you need?", "next": "quest_menu" },
            { "text": "Tell me about this place.", "next": "lore" },
            { "text": "I'll be on my way.", "next": "farewell" }
          ]
        },
        "quest_menu": {
          "text": "We have two urgent needs. The fences need repair — I need 3 pieces of wood. And spirits haunt the ruins to the east.",
          "choices": [
            { "text": "I'll gather the wood.", "next": "quest_wood_accept", "action": "start_quest_gather_wood" },
            { "text": "I'll deal with the spirits.", "next": "quest_spirit_accept", "action": "start_quest_spirit_hunt" },
            { "text": "Maybe later.", "next": "farewell" }
          ]
        },
        "quest_wood_accept": {
          "text": "Bless you! Gather 3 pieces of wood from the forest and return to me.",
          "choices": [{ "text": "On my way!", "next": null }]
        },
        "quest_spirit_accept": {
          "text": "Be careful — the spirits are powerful. Head east past the river to the ruins. Banish 2 of them.",
          "choices": [{ "text": "I'll return victorious.", "next": null }]
        },
        "lore": {
          "text": "This forest has stood for centuries. The river separates our village from the eastern wilds. Strange spirits appeared after treasure hunters disturbed the old ruins.",
          "choices": [{ "text": "Interesting. Thank you.", "next": "farewell" }]
        },
        "quest_check": {
          "text": "Have you gathered the wood? Our fences won't hold much longer!",
          "choices": [
            { "text": "Not yet...", "next": "farewell" },
            { "text": "I have 3 wood!", "next": "quest_wood_complete", "action": "complete_quest_gather_wood" }
          ]
        },
        "quest_wood_complete": {
          "text": "Wonderful! The village is safer now. Take these potions as thanks, brave soul!",
          "choices": [{ "text": "Happy to help!", "next": null }]
        },
        "farewell": {
          "text": "Safe travels, and be wary of wolves after dark.",
          "choices": []
        },
        "repeat": {
          "text": "Back again? Any progress on the tasks I gave you?",
          "choices": [
            { "text": "Still working on it.", "next": "farewell" },
            { "text": "I have 3 wood!", "next": "quest_wood_complete", "action": "complete_quest_gather_wood" }
          ]
        }
      }
    },
    {
      "id": "merchant",
      "name": "Finn the Merchant",
      "role": "merchant",
      "x": 16, "y": 8,
      "sprite": "npc_merchant",
      "schedule": [
        { "startHour": 7,  "endHour": 20, "behavior": "patrol", "path": [[16,8],[18,8],[18,12],[16,12]] },
        { "startHour": 20, "endHour": 24, "behavior": "idle",   "position": [16, 9] },
        { "startHour": 0,  "endHour": 7,  "behavior": "idle",   "position": [16, 9] }
      ],
      "dialogue": {
        "initial": {
          "text": "Finn's trading post — best deals in the forest! I buy wolf fangs for good gear. Got 3 wolf fangs? I'll give you a fine amulet!",
          "choices": [
            { "text": "I have 3 wolf fangs!", "next": "trade_fangs", "action": "start_quest_wolf_fangs" },
            { "text": "What's your secret stock?", "next": "shop" },
            { "text": "Just browsing.", "next": "farewell" }
          ]
        },
        "shop": {
          "text": "My finest wares: potions, energy tonics, and sometimes rare equipment. Check your inventory for anything I may have slipped in!",
          "choices": [{ "text": "Thanks!", "next": "farewell" }]
        },
        "trade_fangs": {
          "text": "Three fangs? Excellent quality! Here's a Wolf Amulet — it channels the wolf's power.",
          "choices": [{ "text": "Amazing, thank you!", "next": null, "action": "complete_quest_wolf_fangs" }]
        },
        "farewell": {
          "text": "Come back soon! Prices won't stay this good forever!",
          "choices": []
        },
        "repeat": {
          "text": "Back for more deals? The wolf fang offer still stands!",
          "choices": [
            { "text": "I have 3 wolf fangs!", "next": "trade_fangs", "action": "complete_quest_wolf_fangs" },
            { "text": "Just passing through.", "next": "farewell" }
          ]
        }
      }
    },
    {
      "id": "guard",
      "name": "Captain Bren",
      "role": "guard",
      "x": 8, "y": 12,
      "sprite": "npc_guard",
      "schedule": [
        { "startHour": 0,  "endHour": 24, "behavior": "patrol", "path": [[8,12],[12,12],[12,8],[8,8]] }
      ],
      "dialogue": {
        "initial": {
          "text": "Halt! ... Oh, a traveler. Sorry. Tensions are high — slimes to the north, wolves everywhere. I'm posting bounties.",
          "choices": [
            { "text": "I'll take the slime bounty.", "next": "slime_quest", "action": "start_quest_slay_slimes" },
            { "text": "What about the wolves?", "next": "wolf_quest", "action": "start_quest_slay_wolves" },
            { "text": "Stay safe, Captain.", "next": "farewell" }
          ]
        },
        "slime_quest": {
          "text": "Kill 3 slimes to the north and west. They're slow but their gel is corrosive. Leather armor won't hurt.",
          "choices": [{ "text": "Consider it done.", "next": null }]
        },
        "wolf_quest": {
          "text": "Wolves patrol the deep forest and eastern reaches. Take down 3 of them. A Silver Sword is your reward.",
          "choices": [{ "text": "I'll bring back proof.", "next": null }]
        },
        "farewell": {
          "text": "Watch your back out there.",
          "choices": []
        },
        "repeat": {
          "text": "How's the hunting going? Those beasts won't kill themselves.",
          "choices": [{ "text": "Making progress.", "next": "farewell" }]
        }
      }
    },
    {
      "id": "healer",
      "name": "Sage Lyra",
      "role": "healer",
      "x": 10, "y": 14,
      "sprite": "npc_healer",
      "schedule": [
        { "startHour": 6,  "endHour": 20, "behavior": "idle", "position": [10, 14] },
        { "startHour": 20, "endHour": 6,  "behavior": "idle", "position": [10, 14] }
      ],
      "dialogue": {
        "initial": {
          "text": "Welcome, weary one. I can restore your vitality. Give me a herb and I'll heal you fully.",
          "choices": [
            { "text": "Heal me (costs 1 Herb).", "next": "heal_done", "action": "heal_player" },
            { "text": "No thanks, I'm fine.", "next": "farewell" }
          ]
        },
        "heal_done": {
          "text": "There — your wounds are mended. Come back anytime the forest tests you.",
          "choices": []
        },
        "farewell": {
          "text": "May the forest light guide you.",
          "choices": []
        },
        "repeat": {
          "text": "Back already? The forest can be brutal. Another herb and I'll patch you up.",
          "choices": [
            { "text": "Please heal me (1 Herb).", "next": "heal_done", "action": "heal_player" },
            { "text": "I'm alright.", "next": "farewell" }
          ]
        }
      }
    }
  ],
