# ============================================================
# Forest Realm RPG — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your Supabase values.
# Get these from: Supabase Dashboard → Settings → API
# ============================================================

# Your Supabase project URL (e.g. https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Optional ────────────────────────────────────────────────
# If these are NOT set, the game runs in offline mode:
#  - Login/Register UI still shows but auth is disabled
#  - Multiplayer realtime is disabled
#  - Save/load uses localStorage only
